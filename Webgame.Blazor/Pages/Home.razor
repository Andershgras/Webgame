@page "/"
@implements IAsyncDisposable
@using Webgame.Blazor.Api
@using Webgame.Blazor.State
@using Webgame.Contracts.Players
@using Webgame.Contracts.Upgrades

@inject ApiClient Api
@inject PlayerSession Session

<h3>Webgame</h3>
<p>Stored playerId: @_storedIdText</p>

@if (_player is null)
{
    <h4>Create Player</h4>

    <div style="margin-bottom:12px;">
        <input @bind="_playerName" placeholder="Enter player name" />
        <button @onclick="Create" disabled="@_isCreating" style="margin-left:8px;">
            @(_isCreating ? "Creating..." : "Create Player")
        </button>
    </div>
}
else
{
    <p><b>Name:</b> @_player.Name</p>
    <p><b>Coins:</b> @_player.Coins</p>
    <p><b>Click Power:</b> @_player.ClickPower</p>
    <p><b>Clicks Per Second:</b> @_player.ClicksPerSecond</p>
    <p><b>Offline Cap:</b> @(_player.OfflineCapSeconds / 60) min</p>

    <button @onclick="Click" disabled="@_isBusy">Click</button>

    <h4>Upgrades</h4>
    @foreach (var u in _upgrades)
    {
        <div>
            <b>@u.Name</b> (lvl @u.CurrentLevel) – cost @u.NextCost
            <button disabled="@(!u.CanAfford || _isBusy)" @onclick="() => Buy(u.Key)">Buy</button>
        </div>
    }
}
@if (_player is not null && _player.OfflineCoinsEarned > 0)
{
    <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
        <b>Offline Progress:</b><br />
        You earned @_player.OfflineCoinsEarned coins<br />
        over @(_player.OfflineSecondsApplied / 60) minute(s)
    </div>
}
@if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="border:1px solid #f00; padding:12px; margin-bottom:12px;">
        <b>Error:</b> @_error
        @if (!string.IsNullOrWhiteSpace(_traceId))
        {
            <div style="opacity:0.7; font-size: 0.9em;">traceId: @_traceId</div>
        }
        <button @onclick="ClearError" style="margin-top:8px;">Dismiss</button>
    </div>
}

@code {
    private PlayerResponse? _player;
    private IReadOnlyList<UpgradeCatalogEntry> _upgrades = [];
    private string _storedIdText = "(not loaded)";
    private bool _loadedFromStorage;

    private string _playerName = "";
    private bool _isCreating;
    private bool _isBusy;
    private bool _isTicking;

    private CancellationTokenSource? _autoTickCts;
    private Task? _autoTickTask;

    private string? _error;
    private string? _traceId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedFromStorage)
            return;

        _loadedFromStorage = true;

        var storedId = await Session.GetPlayerIdAsync();
        _storedIdText = storedId?.ToString() ?? "(null)";

        if (storedId is null)
            return;

        try
        {
            _player = await Api.GetPlayerAsync(storedId.Value);
            await LoadUpgrades();
            EnsureAutoTickRunning();
            StateHasChanged();
        }
        catch
        {
            await Session.ClearAsync();
            _storedIdText = "(null)";
        }
    }

    private async Task Create()
    {
        ClearError();

        if (string.IsNullOrWhiteSpace(_playerName))
        {
            _error = "Name is required.";
            return;
        }

        _isCreating = true;

        try
        {
            _player = await Api.CreatePlayerAsync(_playerName.Trim());
            await Session.SetPlayerIdAsync(_player.Id);
            _storedIdText = _player.Id.ToString();
            await LoadUpgrades();
            EnsureAutoTickRunning();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task Click()
    {
        if (_player is null || _isBusy)
            return;

        ClearError();
        _isBusy = true;

        try
        {
            _player = await Api.ClickAsync(_player.Id);
            await LoadUpgrades();
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task Tick()
    {
        if (_player is null || _isTicking)
            return;

        ClearError();
        _isTicking = true;

        try
        {
            _player = await Api.TickAsync(_player.Id);
            await LoadUpgrades();
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isTicking = false;
        }
    }

    private async Task Buy(string key)
    {
        if (_player is null || _isBusy)
            return;

        ClearError();
        _isBusy = true;

        try
        {
            var res = await Api.BuyUpgradeAsync(_player.Id, key);
            _player = res.Player;
            await LoadUpgrades();
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task LoadUpgrades()
    {
        if (_player is null)
            return;

        _upgrades = await Api.GetUpgradesAsync(_player.Id);
    }

    private void EnsureAutoTickRunning()
    {
        if (_player is null)
            return;

        if (_autoTickTask is not null && !_autoTickTask.IsCompleted)
            return;

        _autoTickCts = new CancellationTokenSource();
        _autoTickTask = RunAutoTickAsync(_autoTickCts.Token);
    }

    private async Task RunAutoTickAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (_player is null)
                    continue;

                if (_isTicking)
                    continue;

                await Tick();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopAutoTick()
    {
        if (_autoTickCts is null)
            return;

        _autoTickCts.Cancel();
        _autoTickCts.Dispose();
        _autoTickCts = null;
        _autoTickTask = null;
    }

    private void ClearError()
    {
        _error = null;
        _traceId = null;
    }

    private void SetError(Exception ex)
    {
        if (ex is ApiException apiEx)
        {
            _error = apiEx.UserMessage;
            _traceId = apiEx.Trace;
            return;
        }

        _error = ex.Message;
        _traceId = null;
    }

    public ValueTask DisposeAsync()
    {
        StopAutoTick();
        return ValueTask.CompletedTask;
    }
}