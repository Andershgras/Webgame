@page "/"
@using System.Net
@using Webgame.Blazor.Api
@using Webgame.Blazor.State
@using Webgame.Contracts.Players

@inject ApiClient Api
@inject PlayerSession Session
@inject PlayerUiState PlayerUiState

@if (_player is null)
{
    <h3>Webgame</h3>

    <h4>Login / Register</h4>

    <div style="margin-bottom:12px;">
        <input @bind="_playerName" placeholder="Enter player name" />
    </div>

    <div style="margin-bottom:12px;">
        <input @bind="_password" type="password" placeholder="Enter password" />
    </div>

    <div style="margin-bottom:12px;">
        <button @onclick="Register" disabled="@(_isCreating || _isLoggingIn)">
            @(_isCreating ? "Creating..." : "Register")
        </button>

        <button @onclick="Login" disabled="@(_isCreating || _isLoggingIn)" style="margin-left:8px;">
            @(_isLoggingIn ? "Logging in..." : "Login")
        </button>
    </div>
}
else
{
    <h3>Welcome, @_player.Name!</h3>

    @if (!_player.HasUnlockedFirstGame)
    {
        <button @onclick="StartFirstGame" style="margin-top:12px;">Start - First Game</button>
    }

    @if (_player.HasUnlockedFirstGame)
    {
        <div style="margin-top:16px; border:1px solid #ccc; padding:12px;">
            <h4>Game #1</h4>
        </div>
    }

    <button @onclick="Logout" style="margin-top:12px;">Logout</button>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="border:1px solid #f00; padding:12px; margin-top:12px;">
        <b>Error:</b> @_error
        <button @onclick="ClearError" style="margin-left:8px;">Dismiss</button>
    </div>
}

@code {
    private PlayerResponse? _player;

    private string _playerName = "";
    private string _password = "";

    private bool _isCreating;
    private bool _isLoggingIn;

    private bool _loadedFromStorage;

    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedFromStorage)
            return;

        _loadedFromStorage = true;

        var token = await Session.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
            return;

        try
        {
            _player = await Api.GetMeAsync();
            PlayerUiState.SetPlayer(_player);
            StateHasChanged();
        }
        catch (ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await Session.ClearAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Register()
    {
        ClearError();

        if (!ValidateCredentials())
            return;

        _isCreating = true;

        try
        {
            await Api.RegisterAsync(_playerName.Trim(), _password);

            var login = await Api.LoginAsync(_playerName.Trim(), _password);
            await Session.SetTokenAsync(login.Token);

            _player = await Api.GetMeAsync();
            PlayerUiState.SetPlayer(_player);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task Login()
    {
        ClearError();

        if (!ValidateCredentials())
            return;

        _isLoggingIn = true;

        try
        {
            var login = await Api.LoginAsync(_playerName.Trim(), _password);
            await Session.SetTokenAsync(login.Token);

            _player = await Api.GetMeAsync();
            PlayerUiState.SetPlayer(_player);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
        finally
        {
            _isLoggingIn = false;
        }
    }

    private async Task Logout()
    {
        await Session.ClearAsync();
        _player = null;
        PlayerUiState.Clear();
        _playerName = "";
        _password = "";
    }

    private async Task StartFirstGame()
    {
        ClearError();

        try
        {
            _player = await Api.UnlockFirstGameAsync();
            PlayerUiState.SetPlayer(_player);
        }
        catch (Exception ex)
        {
            await HandleError(ex);
        }
    }

    private bool ValidateCredentials()
    {
        var name = _playerName.Trim();
        var password = _password ?? "";

        if (string.IsNullOrWhiteSpace(name))
        {
            _error = "Name is required.";
            return false;
        }

        if (name.Length < 3 || name.Length > 20)
        {
            _error = "Name must be between 3 and 20 characters.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(password))
        {
            _error = "Password is required.";
            return false;
        }

        if (password.Length < 6)
        {
            _error = "Password must be at least 6 characters.";
            return false;
        }

        return true;
    }

    private async Task HandleError(Exception ex)
    {
        if (ex is ApiException apiEx && apiEx.StatusCode == HttpStatusCode.Unauthorized)
        {
            await Session.ClearAsync();
            _player = null;
            PlayerUiState.Clear();
            _error = "Your session expired. Please log in again.";
            return;
        }

        _error = ex is ApiException a ? a.UserMessage : ex.Message;
    }

    private void ClearError()
    {
        _error = null;
    }
}
