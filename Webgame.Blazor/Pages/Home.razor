@page "/"
@implements IAsyncDisposable
@using System.Net
@using Webgame.Blazor.Api
@using Webgame.Blazor.State
@using Webgame.Contracts.Players
@using Webgame.Contracts.Upgrades

@inject ApiClient Api
@inject PlayerSession Session
@inject PlayerUiState PlayerUiState
@inject MessageService MessageService

@if (_player is null)
{
    <h3>Webgame</h3>
    <p>Auth token stored: @_tokenStatus</p>
}

@if (_player is null)
{
    <h4>Login / Register</h4>

    <div style="margin-bottom:12px;">
        <input @bind="_playerName" placeholder="Enter player name" />
    </div>

    <div style="margin-bottom:12px;">
        <input @bind="_password" type="password" placeholder="Enter password" />
    </div>

    <div style="margin-bottom:12px;">
        <button @onclick="Register" disabled="@(_isCreating || _isLoggingIn)">
            @(_isCreating ? "Creating..." : "Register")
        </button>

        <button @onclick="Login" disabled="@(_isCreating || _isLoggingIn)" style="margin-left:8px;">
            @(_isLoggingIn ? "Logging in..." : "Login")
        </button>
    </div>
}
else
{
    <div style="display:flex; justify-content:center; margin-top:30px;">
        <div style="width:100%; max-width:1000px; text-align:center;">

            <h1 style="margin-bottom:10px;">Webgame</h1>

            <p style="margin:6px 0;">
                <b>Energy:</b> @_player.Energy
            </p>

            <p style="margin:6px 0;">
                <b>Stellar Energy:</b> @_player.StellarEnergy
            </p>

            <p style="margin:6px 0;">
                <b>Storm Energy:</b> @_player.StormEnergy
            </p>

            <p style="margin:6px 0 24px 0;">
                <b>Production / sec:</b> @GetTotalBoardProduction()
            </p>

            @{
                var elapsed = (DateTime.UtcNow - _lastSpawnTime).TotalSeconds;
                var seconds = Math.Min(SpawnIntervalSeconds, elapsed);
            }

            <div style="margin-bottom:20px;">
                <b>Auto spawn:</b> @Math.Round(seconds, 1)s / @SpawnIntervalSeconds s
            </div>

            <div style="margin-bottom:20px; display:flex; justify-content:center; gap:12px; flex-wrap:wrap;">
                <button @onclick="SpawnCore"
                        disabled="@_isBusy"
                        style="padding:10px 18px;">
                    Spawn Core
                </button>

                <button @onclick="MergeSelectedCores"
                        disabled="@(_isBusy || _selectedCoreIds.Count != 2)"
                        style="padding:10px 18px;">
                    Merge Selected
                </button>
            </div>

            <div style="margin:0 auto 30px auto; max-width:760px;">
                <h3 style="margin-bottom:12px;">Core Board</h3>

                <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:12px;">
                    @for (var slot = 0; slot < _player.BoardSlotCount; slot++)
                    {
                        var core = GetCoreAtSlot(slot);
                        var isSelected = core is not null && _selectedCoreIds.Contains(core.Id);

                        <button @onclick="() => ToggleCoreSelection(core)"
                                disabled="@(_isBusy || core is null)"
                                style="@GetBoardSlotStyle(core is not null, isSelected)">
                            @if (core is null)
                            {
                                <div style="opacity:0.45;">Empty</div>
                            }
                            else
                            {
                                <div><b>Tier @core.Tier</b></div>
                                <div style="font-size:0.9em; margin-top:6px;">
                                    +@core.ProductionPerSecond / sec
                                </div>
                            }
                        </button>
                    }
                </div>
            </div>

            <div style="margin:0 auto; max-width:500px; text-align:left;">
                <h3 style="text-align:center; margin-bottom:12px;">Upgrades</h3>

                <div style="max-height:260px; overflow-y:auto; border:1px solid #ccc; padding:12px;">
                    @foreach (var u in _upgrades)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; gap:10px;">
                            <div>
                                <div><b>@u.Name</b></div>
                                <div>Level: @u.CurrentLevel</div>
                                <div>Cost: @u.NextCost</div>
                            </div>

                            <button disabled="@(!u.CanAfford || _isBusy)"
                                    @onclick="() => Buy(u.Key)">
                                Buy
                            </button>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="border:1px solid #f00; padding:12px; margin-bottom:12px;">
        <b>Error:</b> @_error
        @if (!string.IsNullOrWhiteSpace(_traceId))
        {
            <div style="opacity:0.7; font-size: 0.9em;">traceId: @_traceId</div>
        }
        <button @onclick="ClearError" style="margin-top:8px;">Dismiss</button>
    </div>
}

@code {
    private PlayerResponse? _player;
    private IReadOnlyList<UpgradeCatalogEntry> _upgrades = [];

    private string _tokenStatus = "(not loaded)";
    private bool _loadedFromStorage;

    private string _playerName = "";
    private string _password = "";

    private bool _isCreating;
    private bool _isLoggingIn;
    private bool _isBusy;
    private bool _isTicking;

    private readonly HashSet<Guid> _selectedCoreIds = [];

    private CancellationTokenSource? _autoTickCts;
    private Task? _autoTickTask;

    private string? _error;
    private string? _traceId;

    private DateTime _lastSpawnTime = DateTime.UtcNow;
    private const double SpawnIntervalSeconds = 5;
    private CancellationTokenSource? _spawnCts;
    private Task? _spawnTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedFromStorage)
            return;

        _loadedFromStorage = true;

        var token = await Session.GetTokenAsync();
        _tokenStatus = string.IsNullOrWhiteSpace(token) ? "(none)" : "(present)";

        if (string.IsNullOrWhiteSpace(token))
            return;

        try
        {
            var me = await Api.GetMeAsync();
            UpdatePlayer(me, showLevelUpMessage: false);
            await HandleOfflineRewardAsync();
            await LoadUpgrades();
            EnsureAutoTickRunning();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: true);
        }
    }

    private async Task Register()
    {
        ClearError();

        if (!ValidateCredentials())
            return;

        _isCreating = true;

        try
        {
            await Api.RegisterAsync(_playerName.Trim(), _password);

            var login = await Api.LoginAsync(_playerName.Trim(), _password);
            await Session.SetTokenAsync(login.Token);

            _tokenStatus = "(present)";
            var me = await Api.GetMeAsync();
            UpdatePlayer(me, showLevelUpMessage: false);

            await HandleOfflineRewardAsync();
            await LoadUpgrades();
            EnsureAutoTickRunning();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: false);
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task Login()
    {
        ClearError();

        if (!ValidateCredentials())
            return;

        _isLoggingIn = true;

        try
        {
            var login = await Api.LoginAsync(_playerName.Trim(), _password);
            await Session.SetTokenAsync(login.Token);

            _tokenStatus = "(present)";
            var me = await Api.GetMeAsync();
            UpdatePlayer(me, showLevelUpMessage: false);

            await HandleOfflineRewardAsync();
            await LoadUpgrades();
            EnsureAutoTickRunning();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: false);
        }
        finally
        {
            _isLoggingIn = false;
        }
    }

    private async Task Tick()
    {
        if (_player is null || _isTicking)
            return;

        ClearError();
        _isTicking = true;

        try
        {
            var updatedPlayer = await Api.TickAsync();
            UpdatePlayer(updatedPlayer);
            await LoadUpgrades();
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: true);
        }
        finally
        {
            _isTicking = false;
        }
    }

    private async Task SpawnCore()
    {
        if (_player is null || _isBusy)
            return;

        ClearError();
        _isBusy = true;

        try
        {
            var updatedPlayer = await Api.SpawnCoreAsync();
            UpdatePlayer(updatedPlayer);
            await LoadUpgrades();
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task MergeSelectedCores()
    {
        if (_player is null || _isBusy || _selectedCoreIds.Count != 2)
            return;

        ClearError();
        _isBusy = true;

        try
        {
            var ids = _selectedCoreIds.ToList();
            var updatedPlayer = await Api.MergeCoresAsync(ids[0], ids[1]);
            _selectedCoreIds.Clear();
            UpdatePlayer(updatedPlayer);
            await LoadUpgrades();
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ToggleCoreSelection(CoreDto? core)
    {
        if (core is null)
            return;

        if (_selectedCoreIds.Contains(core.Id))
        {
            _selectedCoreIds.Remove(core.Id);
            return;
        }

        if (_selectedCoreIds.Count >= 2)
            return;

        _selectedCoreIds.Add(core.Id);
    }

    private CoreDto? GetCoreAtSlot(int slotIndex)
    {
        return _player?.Cores.FirstOrDefault(c => c.SlotIndex == slotIndex);
    }

    private long GetTotalBoardProduction()
    {
        return _player?.Cores.Sum(c => c.ProductionPerSecond) ?? 0;
    }

    private bool IsBoardFull()
    {
        if (_player is null)
            return true;

        return _player.Cores.Count >= _player.BoardSlotCount;
    }

    private static string GetBoardSlotStyle(bool hasCore, bool isSelected)
    {
        var border = isSelected ? "2px solid #2f80ed" : "1px solid #bbb";
        var background = hasCore ? "#f8f8f8" : "#fcfcfc";

        return $"height:110px; border:{border}; background:{background}; border-radius:10px; cursor:pointer; padding:8px;";
    }

    private async Task Buy(string key)
    {
        if (_player is null || _isBusy)
            return;

        ClearError();
        _isBusy = true;

        try
        {
            var res = await Api.BuyUpgradeAsync(key);
            UpdatePlayer(res.Player);

            await LoadUpgrades();

            var upgraded = _upgrades.FirstOrDefault(u => u.Key == key);
            if (upgraded is not null)
            {
                MessageService.Add(
                    $"{upgraded.Name} upgraded to level {upgraded.CurrentLevel}",
                    "success"
                );
            }
        }
        catch (Exception ex)
        {
            await HandleAuthAwareError(ex, resetPlayer: true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task LoadUpgrades()
    {
        if (_player is null)
            return;

        _upgrades = await Api.GetUpgradesAsync();
    }

    private Task HandleOfflineRewardAsync()
    {
        if (_player is null)
            return Task.CompletedTask;

        if (_player.OfflineEnergyEarned > 0)
        {
            var timeText = _player.OfflineSecondsApplied < 60
                ? $"{_player.OfflineSecondsApplied} second(s)"
                : $"{Math.Ceiling(_player.OfflineSecondsApplied / 60d)} minute(s)";

            MessageService.Add(
                $"You earned {_player.OfflineEnergyEarned} energy over {timeText}",
                "success"
            );
        }

        return Task.CompletedTask;
    }

    private bool ValidateCredentials()
    {
        var name = _playerName.Trim();
        var password = _password ?? "";

        if (string.IsNullOrWhiteSpace(name))
        {
            _error = "Name is required.";
            return false;
        }

        if (name.Length < 3 || name.Length > 20)
        {
            _error = "Name must be between 3 and 20 characters.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(password))
        {
            _error = "Password is required.";
            return false;
        }

        if (password.Length < 6)
        {
            _error = "Password must be at least 6 characters.";
            return false;
        }

        return true;
    }

    private async Task HandleAuthAwareError(Exception ex, bool resetPlayer)
    {
        if (ex is ApiException apiEx && apiEx.StatusCode == HttpStatusCode.Unauthorized)
        {
            await Session.ClearAsync();
            StopAutoTick();

            if (resetPlayer)
            {
                _player = null;
                PlayerUiState.Clear();
                _upgrades = [];
                _selectedCoreIds.Clear();
            }

            _tokenStatus = "(none)";
            _error = "Your session expired. Please log in again.";
            _traceId = apiEx.Trace;
            return;
        }

        SetError(ex);
    }

    private void EnsureAutoTickRunning()
    {
        if (_player is null)
            return;

        if (_autoTickTask is not null && !_autoTickTask.IsCompleted)
            return;

        _autoTickCts = new CancellationTokenSource();
        _autoTickTask = RunAutoTickAsync(_autoTickCts.Token);

        EnsureAutoSpawnRunning();
    }

    private async Task RunAutoTickAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (_player is null)
                    continue;

                if (_isTicking)
                    continue;

                await Tick();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void EnsureAutoSpawnRunning()
    {
        if (_player is null)
            return;

        if (_spawnTask is not null && !_spawnTask.IsCompleted)
            return;

        _spawnCts = new CancellationTokenSource();
        _spawnTask = RunAutoSpawnAsync(_spawnCts.Token);
    }

    private async Task RunAutoSpawnAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(100, ct);

                if (_player is null)
                    continue;

                if (IsBoardFull())
                {
                    _lastSpawnTime = DateTime.UtcNow;
                    await InvokeAsync(StateHasChanged);
                    continue;
                }

                var elapsed = (DateTime.UtcNow - _lastSpawnTime).TotalSeconds;
                var progress = elapsed / SpawnIntervalSeconds;

                if (progress >= 1)
                {
                    _lastSpawnTime = DateTime.UtcNow;

                    if (!_isBusy)
                    {
                        await SpawnCore();
                    }
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopAutoTick()
    {
        if (_autoTickCts is not null)
        {
            _autoTickCts.Cancel();
            _autoTickCts.Dispose();
            _autoTickCts = null;
            _autoTickTask = null;
        }

        if (_spawnCts is not null)
        {
            _spawnCts.Cancel();
            _spawnCts.Dispose();
            _spawnCts = null;
            _spawnTask = null;
        }
    }

    private void ClearError()
    {
        _error = null;
        _traceId = null;
    }

    private void SetError(Exception ex)
    {
        if (ex is ApiException apiEx)
        {
            _error = apiEx.UserMessage;
            _traceId = apiEx.Trace;
            return;
        }

        _error = ex.Message;
        _traceId = null;
    }

    public ValueTask DisposeAsync()
    {
        StopAutoTick();
        return ValueTask.CompletedTask;
    }

    private void SyncPlayerUiState()
    {
        PlayerUiState.SetPlayer(_player);
    }

    private void UpdatePlayer(PlayerResponse newPlayer, bool showLevelUpMessage = true)
    {
        var oldLevel = _player?.Level ?? 0;

        _player = newPlayer;
        SyncPlayerUiState();

        var validCoreIds = _player.Cores.Select(c => c.Id).ToHashSet();
        _selectedCoreIds.RemoveWhere(id => !validCoreIds.Contains(id));

        if (showLevelUpMessage && newPlayer.Level > oldLevel)
        {
            MessageService.Add($"Level up! You reached level {newPlayer.Level}", "success");
        }
    }
}