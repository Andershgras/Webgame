@page "/profile"
@using System.Net
@using Webgame.Blazor.Api
@using Webgame.Blazor.State
@using Webgame.Contracts.Players

@inject ApiClient Api
@inject PlayerSession Session
@inject NavigationManager Nav
@inject PlayerUiState PlayerUiState

<h3>Profile</h3>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_player is null)
{
    <p>No player loaded.</p>
}
else
{
    <p><b>Name:</b> @_player.Name</p>
    <p><b>Level:</b> @_player.Level</p>
    <p><b>Energy:</b> @_player.Energy</p>
    <p><b>Stellar Energy:</b> @_player.StellarEnergy</p>
    <p><b>Storm Energy:</b> @_player.StormEnergy</p>

    <h4>Board</h4>
    <p><b>Board Slots:</b> @_player.BoardSlotCount</p>
    <p><b>Owned Cores:</b> @_player.Cores.Count</p>
    <p><b>Total Production / Second:</b> @GetTotalBoardProduction()</p>

    @if (_player.Cores.Count > 0)
    {
        <div style="margin-bottom:16px;">
            @foreach (var core in _player.Cores.OrderBy(c => c.SlotIndex))
            {
                <div style="padding:8px; border:1px solid #ddd; margin-bottom:8px; border-radius:8px;">
                    <b>Slot @core.SlotIndex</b> - Tier @core.Tier
                    <div style="opacity:0.8;">+@core.ProductionPerSecond energy/sec</div>
                </div>
            }
        </div>
    }
    else
    {
        <p>No cores yet.</p>
    }

    <h4>Current Progression</h4>
    <p><b>Click Power:</b> @_player.ClickPower</p>
    <p><b>Legacy Production / Second:</b> @_player.ClicksPerSecond</p>
    <p><b>Offline Cap:</b> @(_player.OfflineCapSeconds / 60) min</p>

    <h4>Lifetime Stats</h4>
    <p><b>Total Clicks:</b> @_player.TotalClicks</p>
    <p><b>Total Energy Earned:</b> @_player.TotalEnergyEarned</p>
    <p><b>Total Energy Spent:</b> @_player.TotalEnergySpent</p>
    <p><b>Total Merges:</b> @_player.TotalMerges</p>

    <button @onclick="Logout">Logout</button>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="border:1px solid #f00; padding:12px; margin-bottom:12px;">
        <b>Error:</b> @_error
    </div>
}

@code {
    private PlayerResponse? _player;
    private string? _error;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _player = await Api.GetMeAsync();
            PlayerUiState.SetPlayer(_player);
        }
        catch (Exception ex)
        {
            if (ex is ApiException apiEx && apiEx.StatusCode == HttpStatusCode.Unauthorized)
            {
                await Session.ClearAsync();
                PlayerUiState.Clear();
                _error = "Your session expired. Please log in again.";
            }
            else
            {
                _error = ex.Message;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private long GetTotalBoardProduction()
    {
        return _player?.Cores.Sum(c => c.ProductionPerSecond) ?? 0;
    }

    private async Task Logout()
    {
        await Session.ClearAsync();
        PlayerUiState.Clear();
        Nav.NavigateTo("/", forceLoad: false);
    }
}