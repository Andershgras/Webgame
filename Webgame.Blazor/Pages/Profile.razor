@page "/profile"
@using System.Net
@using Webgame.Blazor.Api
@using Webgame.Blazor.State
@using Webgame.Contracts.Players

@inject ApiClient Api
@inject PlayerSession Session
@inject NavigationManager Nav
@inject PlayerUiState PlayerUiState

<h3>Profile</h3>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_player is null)
{
    <p>No player loaded.</p>
}
else
{
    <p><b>Name:</b> @_player.Name</p>
    <p><b>Level:</b> @_player.Level</p>
    <p><b>Coins:</b> @_player.Coins</p>
    <p><b>Click Power:</b> @_player.ClickPower</p>
    <p><b>Clicks Per Second:</b> @_player.ClicksPerSecond</p>
    <p><b>Offline Cap:</b> @(_player.OfflineCapSeconds / 60) min</p>

    <h4>Lifetime Stats</h4>
    <p><b>Total Clicks:</b> @_player.TotalClicks</p>
    <p><b>Total Coins Earned:</b> @_player.TotalCoinsEarned</p>
    <p><b>Total Coins Spent:</b> @_player.TotalCoinsSpent</p>

    <button @onclick="Logout">Logout</button>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="border:1px solid #f00; padding:12px; margin-bottom:12px;">
        <b>Error:</b> @_error
    </div>
}

@code {
    private PlayerResponse? _player;
    private string? _error;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _player = await Api.GetMeAsync();
            PlayerUiState.SetPlayer(_player);
        }
        catch (Exception ex)
        {
            if (ex is ApiException apiEx && apiEx.StatusCode == HttpStatusCode.Unauthorized)
            {
                await Session.ClearAsync();
                PlayerUiState.Clear();
                _error = "Your session expired. Please log in again.";
            }
            else
            {
                _error = ex.Message;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Logout()
    {
        await Session.ClearAsync();
        PlayerUiState.Clear();
        Nav.NavigateTo("/", forceLoad: false);
    }
}